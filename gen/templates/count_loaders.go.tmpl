{{- /* Template: count_loaders.go.tmpl - generates count loading for HasMany/ManyToMany */ -}}
{{- $tableName := .Table.Name -}}
{{- $structName := pascal (singular $tableName) -}}
{{- $sliceType := printf "%sSlice" $structName -}}
{{- $relsType := printf "%sRels" $structName -}}
