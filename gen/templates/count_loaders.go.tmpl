{{- if $hasCountRels}}

// {{lower $structName}}CountLoaders maps relationship names to their count loader functions.
var {{lower $structName}}CountLoaders = map[string]runtime.CountLoadFunc{}

func init() {
{{- range .Table.Relationships}}
{{- if or (eq .Type (relHasMany)) (eq .Type (relManyToMany))}}
	{{lower $structName}}CountLoaders["{{relFieldName . $.Table}}"] = loadCount{{$structName}}{{relFieldName . $.Table}}
{{- end}}
{{- end}}
}

// LoadCountRelations loads counts for the specified relationships.
// Pass relationship names (e.g., "Posts", "Tags") to load their counts.
func (s {{$sliceType}}) LoadCountRelations(ctx context.Context, exec runtime.Executor, names ...string) error {
	for _, name := range names {
		fn, ok := {{lower $structName}}CountLoaders[name]
		if !ok {
			return fmt.Errorf("unknown count relationship %q on {{$structName}}", name)
		}
		if err := fn(ctx, exec, dialect, s); err != nil {
			return fmt.Errorf("loading count for %s: %w", name, err)
		}
	}
	return nil
}

{{range $rel := .Table.Relationships}}
{{- $fieldName := relFieldName $rel $.Table -}}

{{- if eq $rel.Type (relHasMany)}}
{{- $localCol := index $rel.Columns 0 -}}
{{- $foreignCol := index $rel.ForeignColumns 0}}
func loadCount{{$structName}}{{$fieldName}}(ctx context.Context, exec runtime.Executor, d runtime.Dialect, parentModels any) error {
	models := parentModels.({{$sliceType}})
	if len(models) == 0 {
		return nil
	}

	ids := make([]any, len(models))
	for i, m := range models {
		ids[i] = m.{{pascal $localCol}}
	}

	counts, err := runtime.LoadCount(ctx, exec, d, "{{$rel.ForeignTable}}", "{{$foreignCol}}", ids)
	if err != nil {
		return err
	}

	for _, m := range models {
		if m.R == nil {
			m.R = &{{$relsType}}{}
		}
		key := fmt.Sprint(m.{{pascal $localCol}})
		c := counts[key]
		m.R.{{$fieldName}}Count = &c
	}
	return nil
}

{{- else if eq $rel.Type (relManyToMany)}}
{{- $localCol := index $rel.Columns 0 -}}
{{- $joinLocalCol := index $rel.JoinLocalColumns 0 -}}
{{- $joinForeignCol := index $rel.JoinForeignColumns 0}}
func loadCount{{$structName}}{{$fieldName}}(ctx context.Context, exec runtime.Executor, d runtime.Dialect, parentModels any) error {
	models := parentModels.({{$sliceType}})
	if len(models) == 0 {
		return nil
	}

	ids := make([]any, len(models))
	for i, m := range models {
		ids[i] = m.{{pascal $localCol}}
	}

	counts, err := runtime.LoadManyToManyCount(ctx, exec, d, "{{$rel.JoinTable}}", "{{$joinLocalCol}}", "{{$joinForeignCol}}", ids)
	if err != nil {
		return err
	}

	for _, m := range models {
		if m.R == nil {
			m.R = &{{$relsType}}{}
		}
		key := fmt.Sprint(m.{{pascal $localCol}})
		c := counts[key]
		m.R.{{$fieldName}}Count = &c
	}
	return nil
}
