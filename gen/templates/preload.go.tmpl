{{- /* Template: preload.go.tmpl - generates LEFT JOIN preload support for to-one relationships */ -}}
{{- $tableName := .Table.Name -}}
{{- $structName := pascal (singular $tableName) -}}
{{- $relsType := printf "%sRels" $structName -}}
// Code generated by sqlgen. DO NOT EDIT.

package {{.Package}}

{{.Imports}}

{{- range $rel := .Table.Relationships}}
{{- if or (eq $rel.Type (relBelongsTo)) (eq $rel.Type (relHasOne))}}
{{- $fieldName := relFieldName $rel $.Table -}}
{{- $foreignStructName := pascal (singular $rel.ForeignTable) -}}
{{- $foreignTable := findTable $.AllTables $rel.ForeignTable -}}
{{- $localCol := index $rel.Columns 0 -}}
{{- $foreignCol := index $rel.ForeignColumns 0}}

// {{lower $structName}}{{$fieldName}}Preload holds nullable scan targets for LEFT JOINed {{$foreignStructName}} columns.
type {{lower $structName}}{{$fieldName}}Preload struct {
{{- range $foreignTable.Columns}}
	{{safeCamel .Name}} {{nullGoType . $foreignTable.Name}}
{{- end}}
}

func (p *{{lower $structName}}{{$fieldName}}Preload) scanDests() []any {
	return []any{
{{- range $foreignTable.Columns}}
		&p.{{safeCamel .Name}},
{{- end}}
	}
}

func (p *{{lower $structName}}{{$fieldName}}Preload) assign(o *{{$structName}}) {
{{- /* Check if the PK of the foreign table is valid (row exists). */}}
{{- $foreignPK := index $foreignTable.PrimaryKey.Columns 0}}
	if !p.{{safeCamel $foreignPK}}.Valid {
		return
	}
	if o.R == nil {
		o.R = &{{$relsType}}{}
	}
	o.R.{{$fieldName}} = &{{$foreignStructName}}{
{{- range $foreignTable.Columns}}
{{- if .IsNullable}}
		{{pascal .Name}}: p.{{safeCamel .Name}},
{{- else}}
		{{pascal .Name}}: p.{{safeCamel .Name}}.Val,
{{- end}}
{{- end}}
	}
}

// {{$structName}}Preload{{$fieldName}} is the PreloadDef for the {{$fieldName}} relationship.
{{- if eq $rel.Type (relBelongsTo)}}
var {{$structName}}Preload{{$fieldName}} = sqlgen.PreloadDef{
	Name:     "{{$fieldName}}",
	Table:    {{$foreignStructName}}TableName,
	JoinCond: "\"{{$rel.ForeignTable}}\".\"{{$foreignCol}}\" = \"{{$tableName}}\".\"{{$localCol}}\"",
	Columns:  []string{
{{- range $foreignTable.Columns}}
		"\"{{$rel.ForeignTable}}\".\"{{.Name}}\"",
{{- end}}
	},
}
{{- else}}
{{- /* HasOne: foreign table has FK pointing to this table's PK */}}
var {{$structName}}Preload{{$fieldName}} = sqlgen.PreloadDef{
	Name:     "{{$fieldName}}",
	Table:    {{$foreignStructName}}TableName,
	JoinCond: "\"{{$rel.ForeignTable}}\".\"{{$foreignCol}}\" = \"{{$tableName}}\".\"{{$localCol}}\"",
	Columns:  []string{
{{- range $foreignTable.Columns}}
		"\"{{$rel.ForeignTable}}\".\"{{.Name}}\"",
{{- end}}
	},
}
{{- end}}

{{- end}}
{{- end}}

{{- /* Preload state factory: maps relationship name to preload state */ -}}
{{- $hasToOne := false}}
{{- range .Table.Relationships}}
{{- if or (eq .Type (relBelongsTo)) (eq .Type (relHasOne))}}
{{- $hasToOne = true}}
{{- end}}
{{- end}}

{{- if $hasToOne}}

// {{lower $structName}}PreloadState is the interface for preload scan states.
type {{lower $structName}}PreloadState interface {
	scanDests() []any
	assign(o *{{$structName}})
}

// new{{$structName}}PreloadState returns a preload state for the named relationship.
func new{{$structName}}PreloadState(name string) {{lower $structName}}PreloadState {
	switch name {
{{- range $rel := .Table.Relationships}}
{{- if or (eq $rel.Type (relBelongsTo)) (eq $rel.Type (relHasOne))}}
{{- $fieldName := relFieldName $rel $.Table}}
	case "{{$fieldName}}":
		return &{{lower $structName}}{{$fieldName}}Preload{}
{{- end}}
{{- end}}
	}
	return nil
}
{{- end}}
