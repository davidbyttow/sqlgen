{{- /* Template: model.go.tmpl - generates model struct for a table */ -}}
{{- $tableName := .Table.Name -}}
{{- $structName := pascal (singular $tableName) -}}
{{- $tableConst := printf "%sTableName" $structName -}}
// Code generated by sqlgen. DO NOT EDIT.

package {{.Package}}

{{.Imports}}

// {{$tableConst}} is the database table name.
const {{$tableConst}} = "{{$tableName}}"

// {{$structName}}Columns contains all column names for the {{$tableName}} table.
var {{$structName}}Columns = struct {
{{- range .Table.Columns}}
	{{pascal .Name}} string
{{- end}}
}{
{{- range .Table.Columns}}
	{{pascal .Name}}: "{{.Name}}",
{{- end}}
}

// {{$structName}} represents a row from the '{{$tableName}}' table.
type {{$structName}} struct {
{{- range .Table.Columns}}
	{{pascal .Name}} {{goType .}} {{structTags . $.Tags}}
{{- end}}

	R *{{$structName}}Rels {{relTags $.Tags}}
}

// {{$structName}}Rels holds eagerly loaded relationships.
type {{$structName}}Rels struct {
{{- range .Table.Relationships}}
{{- if eq .Type (relBelongsTo)}}
	{{relFieldName . $.Table}} *{{pascal (singular .ForeignTable)}}
{{- else if eq .Type (relHasOne)}}
	{{relFieldName . $.Table}} *{{pascal (singular .ForeignTable)}}
{{- else if eq .Type (relHasMany)}}
	{{relFieldName . $.Table}} []*{{pascal (singular .ForeignTable)}}
{{- else if eq .Type (relManyToMany)}}
	{{relFieldName . $.Table}} []*{{pascal (singular .ForeignTable)}}
{{- end}}
{{- end}}
}

// {{$structName}}Slice is a slice of {{$structName}} pointers.
type {{$structName}}Slice []*{{$structName}}

// ScanRow scans a database row into a {{$structName}}.
func (o *{{$structName}}) ScanRow(rows interface{ Scan(...any) error }) error {
	return rows.Scan(
{{- range .Table.Columns}}
		&o.{{pascal .Name}},
{{- end}}
	)
}

// scanDests returns scan destinations for all columns (used by preload-aware queries).
func (o *{{$structName}}) scanDests() []any {
	return []any{
{{- range .Table.Columns}}
		&o.{{pascal .Name}},
{{- end}}
	}
}
