{{- /* Template: test.go.tmpl - generates tests for a table's model and query builders */ -}}
{{- $tableName := .Table.Name -}}
{{- $structName := pascal (singular $tableName) -}}
{{- $tableConst := printf "%sTableName" $structName -}}
// Code generated by sqlgen. DO NOT EDIT.

package {{.Package}}

import (
	"testing"

	"github.com/davidbyttow/sqlgen"
)

func Test{{$structName}}TableName(t *testing.T) {
	if {{$tableConst}} != "{{$tableName}}" {
		t.Errorf("{{$tableConst}} = %q, want %q", {{$tableConst}}, "{{$tableName}}")
	}
}

func Test{{$structName}}Columns(t *testing.T) {
	// Verify column constants match expected names.
	cols := map[string]string{
{{- range .Table.Columns}}
		"{{pascal .Name}}": "{{.Name}}",
{{- end}}
	}
	vals := map[string]string{
{{- range .Table.Columns}}
		"{{pascal .Name}}": {{$structName}}Columns.{{pascal .Name}},
{{- end}}
	}
	for name, want := range cols {
		got := vals[name]
		if got != want {
			t.Errorf("column %s = %q, want %q", name, got, want)
		}
	}
}

func Test{{$structName}}FieldCount(t *testing.T) {
	o := &{{$structName}}{}
	_ = o
}

func Test{{$structName}}QueryBuilder(t *testing.T) {
	q := {{safePascal (plural (singular $tableName))}}()
	sql, args := q.BuildSelect()
	if sql == "" {
		t.Error("BuildSelect returned empty SQL")
	}
	if len(args) != 0 {
		t.Errorf("expected 0 args for unfiltered query, got %d", len(args))
	}

	// With a where clause and limit.
	q = {{safePascal (plural (singular $tableName))}}(
		sqlgen.Where("1 = ?", 1),
		sqlgen.Limit(10),
	)
	sql, args = q.BuildSelect()
	if sql == "" {
		t.Error("BuildSelect with where returned empty SQL")
	}
	if len(args) == 0 {
		t.Error("expected args for filtered query, got 0")
	}
}

{{- range .Table.Columns}}

func Test{{$structName}}Where{{pascal .Name}}(t *testing.T) {
	// EQ
	mod := {{$structName}}Where.{{pascal .Name}}.EQ({{testZeroVal .}})
	q := {{safePascal (plural (singular $tableName))}}(mod)
	sql, args := q.BuildSelect()
	if sql == "" {
		t.Error("EQ query is empty")
	}
	if len(args) != 1 {
		t.Errorf("EQ expected 1 arg, got %d", len(args))
	}

	// IN
	mod = {{$structName}}Where.{{pascal .Name}}.IN({{testZeroVal .}}, {{testZeroVal .}})
	q = {{safePascal (plural (singular $tableName))}}(mod)
	sql, args = q.BuildSelect()
	if sql == "" {
		t.Error("IN query is empty")
	}
	if len(args) != 2 {
		t.Errorf("IN expected 2 args, got %d", len(args))
	}
{{- if isNullable .}}

	// IsNull / IsNotNull
	q = {{safePascal (plural (singular $tableName))}}({{$structName}}Where.{{pascal .Name}}.IsNull())
	sql, _ = q.BuildSelect()
	if sql == "" {
		t.Error("IsNull query is empty")
	}
	q = {{safePascal (plural (singular $tableName))}}({{$structName}}Where.{{pascal .Name}}.IsNotNull())
	sql, _ = q.BuildSelect()
	if sql == "" {
		t.Error("IsNotNull query is empty")
	}
{{- end}}
}
{{- end}}

{{- if .Table.PrimaryKey}}

func Test{{$structName}}BuildUpdateAll(t *testing.T) {
	q := {{safePascal (plural (singular $tableName))}}(
		sqlgen.Where("1 = ?", 1),
	)
	sql, args := q.BuildUpdateAll(map[string]any{"{{(index .Table.Columns 0).Name}}": nil})
	if sql == "" {
		t.Error("BuildUpdateAll returned empty SQL")
	}
	if len(args) < 2 {
		t.Errorf("expected at least 2 args (set + where), got %d", len(args))
	}
}

func Test{{$structName}}BuildDeleteAll(t *testing.T) {
	q := {{safePascal (plural (singular $tableName))}}(
		sqlgen.Where("1 = ?", 1),
	)
	sql, args := q.BuildDeleteAll()
	if sql == "" {
		t.Error("BuildDeleteAll returned empty SQL")
	}
	if len(args) != 1 {
		t.Errorf("expected 1 arg, got %d", len(args))
	}
}
{{- end}}
